{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@selectors/*": ["src/selectors/*"],
      "@support/*": ["src/support/*"]
    },
    "types": ["node", "@wdio/globals/types", "mocha"]
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": ["src/**/*.ts", "wdio.conf.ts"],
  "exclude": ["node_modules", "dist"]
}
