# GitHub PAT with repo scope — used in trigger-wdio-fixture workflow
GH_PAT=your_token_here

# Target repo for repository_dispatch (owner/repo)
FIXTURE_REPO=your-github-username/time-balancer-wdio-fixture

# Saucedemo credentials (public test site — defaults work without these set)
SAUCE_USER=standard_user
SAUCE_PASS=secret_sauce
