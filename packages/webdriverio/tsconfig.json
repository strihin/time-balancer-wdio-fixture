{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@constants/*": ["../shared/src/constants/*"],
      "@fixtures/*": ["../shared/src/fixtures/*"],
      "@selectors/*": ["../shared/src/selectors/*"],
      "@support/*": ["src/support/*"],
      "@utils/*": ["../shared/src/utils/*"]
    },
    "types": ["node", "@wdio/globals/types", "mocha"]
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": ["src/**/*.ts", "wdio.conf.ts"],
  "exclude": ["node_modules", "dist"]
}
