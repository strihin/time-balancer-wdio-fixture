{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["cypress", "node"],
    "baseUrl": ".",
    "paths": {
      "@config/*": ["../shared/src/config/*"],
      "@fixtures/*": ["../shared/src/fixtures/*"],
      "@selectors/*": ["../shared/src/selectors/*"],
      "@support/*": ["cypress/support/*"]
    }
  },
  "include": ["**/*.ts"]
}
