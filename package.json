{
  "name": "time-balancer-benchmarks",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "cypress:test": "FRAMEWORK=cypress docker-compose up --build --exit-code-from benchmark",
    "playwright:test": "FRAMEWORK=playwright docker-compose up --build --exit-code-from benchmark",
    "puppeteer:test": "FRAMEWORK=puppeteer docker-compose up --build --exit-code-from benchmark",
    "webdriverio:test": "FRAMEWORK=webdriverio docker-compose up --build --exit-code-from benchmark",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check . --apply"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
